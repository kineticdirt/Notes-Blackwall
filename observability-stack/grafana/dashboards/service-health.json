{
  "dashboard": {
    "title": "Cequence BlackWall — Service Health",
    "uid": "cequence-svc-health",
    "panels": [
      {
        "title": "Service Uptime",
        "type": "stat",
        "targets": [{ "expr": "up", "legendFormat": "{{ job }}" }],
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 }
      },
      {
        "title": "Request Rate (req/s)",
        "type": "timeseries",
        "targets": [{ "expr": "rate(http_requests_total[5m])", "legendFormat": "{{ service }} {{ method }}" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
      },
      {
        "title": "Error Rate (%)",
        "type": "timeseries",
        "targets": [{ "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m]) * 100", "legendFormat": "{{ service }}" }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
      },
      {
        "title": "P50 / P95 / P99 Latency",
        "type": "timeseries",
        "targets": [
          { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "P50 {{ service }}" },
          { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "P95 {{ service }}" },
          { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "P99 {{ service }}" }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 }
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "10s"
  }
}
