{
  "name": "performance-orchestrator",
  "version": "1.0.0",
  "description": "High-performance test/benchmark orchestrator with resource profiling and caching",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test test/**/*.test.js",
    "bench": "node src/benchmark.js"
  },
  "keywords": [
    "orchestrator",
    "benchmark",
    "performance",
    "profiling",
    "caching"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
