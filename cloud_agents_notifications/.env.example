# Email Notifications
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_TO=notifications@example.com
EMAIL_FROM=your-email@gmail.com
EMAIL_USE_TLS=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Microsoft Teams
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Pushover
PUSHOVER_API_TOKEN=your-app-token
PUSHOVER_USER_KEY=your-user-key

# Gotify (Self-hosted)
GOTIFY_URL=https://gotify.yourdomain.com
GOTIFY_TOKEN=your-app-token

# Matrix
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@user:matrix.org
MATRIX_ACCESS_TOKEN=syt_...
MATRIX_ROOM_ID=!roomid:matrix.org

# Desktop Notifications (macOS/Linux/Windows)
DESKTOP_NOTIFICATIONS=true

# Custom Webhook
CUSTOM_WEBHOOK_URL=https://your-api.com/webhook
CUSTOM_WEBHOOK_HEADERS={"Authorization": "Bearer token"}

# File Logging
FILE_LOG_PATH=/path/to/notifications.log

# Webhook Security
WEBHOOK_SECRET=your-secret-key-minimum-32-characters-long

# Server Configuration
PORT=8001
